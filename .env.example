# ──────────────────────────────────────────────────────────────
# BunMail — Environment Variables
#
# Copy this file to .env and fill in the values.
# Required variables are marked with (required).
# ──────────────────────────────────────────────────────────────

# ── Environment ──
# "development" — relaxed: allows sending from unregistered domains
# "production"  — strict: requires registered + DKIM-verified domains
BUNMAIL_ENV=development

# ── Database (required) ──
# PostgreSQL connection URL (used when running without Docker Compose)
DATABASE_URL=postgres://bunmail:changeme@localhost:5432/bunmail

# ── Docker Compose Postgres ──
# These are used by docker-compose.yml to configure the PostgreSQL container.
# POSTGRES_PASSWORD is required — pick a strong, unique password.
POSTGRES_USER=bunmail
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bunmail

# ── HTTP Server ──
PORT=3000
HOST=0.0.0.0

# ── Email Delivery ──
# Hostname used in the SMTP HELO command and Message-ID header.
# Should match your server's PTR (reverse DNS) record for best deliverability.
MAIL_HOSTNAME=mail.example.com

# ── Inbound SMTP Server ──
# Set to "true" to enable the inbound SMTP server for receiving emails.
SMTP_ENABLED=false
# Port for the inbound SMTP server (default 2525; use 25 in production with proper permissions)
SMTP_PORT=2525

# ── SMTP Spam Protection ──
# All layers are enabled by default when the SMTP server is on.
# Check connecting IPs against a DNSBL (DNS blackhole list)
SMTP_DNSBL_ENABLED=true
# DNSBL zone to query (Spamhaus ZEN combines SBL + XBL + PBL)
SMTP_DNSBL_ZONE=zen.spamhaus.org
# Reject mail to domains not registered in BunMail
SMTP_RECIPIENT_VALIDATION=true
# Per-IP connection rate limiting
SMTP_RATE_LIMIT_ENABLED=true
# Max connections per IP per window
SMTP_RATE_LIMIT_MAX=10
# Rate limit window in seconds
SMTP_RATE_LIMIT_WINDOW=60

# ── Dashboard ──
# Password for the /dashboard web UI. Leave empty to disable the dashboard.
DASHBOARD_PASSWORD=
# Secret for signing session cookies. Defaults to a random UUID (sessions reset on restart).
SESSION_SECRET=

# ── Logging ──
# Log level: debug, info, warn, error
LOG_LEVEL=info
