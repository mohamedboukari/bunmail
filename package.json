{
  "name": "bunmail",
  "version": "0.5.0",
  "description": "Self-hosted email API for developers — free alternative to SendGrid/Resend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "typecheck": "bunx tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "test": "bun test test/unit test/e2e",
    "test:unit": "bun test test/unit",
    "test:e2e": "bun test test/e2e",
    "test:integration": "bun test --preload ./test/integration/_preload.ts test/integration",
    "test:integration:setup": "bun run test/integration/setup-db.ts",
    "test:all": "bun test test/unit test/e2e && bun run test:integration",
    "test:coverage": "bun test test/unit test/e2e --coverage",
    "release": "bumpp",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "bash -c 'bunx tsc --noEmit'"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/mailparser": "^3.4.6",
    "@types/nodemailer": "^8.0.0",
    "@types/smtp-server": "^3.5.13",
    "bumpp": "^11.0.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "knip": "^6.11.0",
    "lint-staged": "^16.4.0",
    "postgres": "^3.4.9",
    "prettier": "^3.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@elysiajs/html": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@kitajs/html": "^4.2.13",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "fast-xml-parser": "^5.7.3",
    "fflate": "^0.8.2",
    "file-type": "^22.0.1",
    "mailparser": "^3.9.8",
    "nodemailer": "^8.0.7",
    "smtp-server": "^3.18.4"
  },
  "overrides": {
    "defu": "^6.1.7",
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4",
    "yaml": "^2.8.4",
    "file-type": "^22.0.1",
    "brace-expansion": "^5.0.5"
  }
}
